<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Chef Nishanth — Enterprise Control Center</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
:root {
  --bg-dark-core: #0B0E14;
  --bg-dark-surface: #141923;
  --bg-dark-card: #1A202C;
  --text-main: #FFFFFF;
  --text-muted: #8A94A6;
  --color-green: #48C479;
  --color-purple: #A78BFA;
  --color-blue: #60A5FA;
  --color-orange: #F59E0B;
  --color-red: #EF4444;
  --border-line: #2D3748;
  --font-base: 'Poppins', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; font-family: var(--font-base); }
body { background: var(--bg-dark-core); color: var(--text-main); min-height: 100vh; display: flex; overflow-x: hidden; }

/* ── SIDEBAR NAVIGATION ── */
.sidebar { width: 260px; background: var(--bg-dark-surface); border-right: 1px solid var(--border-line); display: flex; flex-direction: column; padding: 24px; position: fixed; height: 100vh; z-index: 100; transition: all 0.3s ease; }
.brand-box { display: flex; align-items: center; gap: 12px; margin-bottom: 40px; }
.brand-logo { font-size: 24px; }
.brand-name { font-size: 18px; font-weight: 700; background: linear-gradient(to right, #FC8019, #FFAB68); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.nav-list { display: flex; flex-direction: column; gap: 8px; list-style: none; flex: 1; }
.nav-item { display: flex; align-items: center; gap: 14px; padding: 12px 16px; border-radius: 10px; color: var(--text-muted); cursor: pointer; font-size: 14px; font-weight: 500; transition: all 0.2s ease; }
.nav-item:hover, .nav-item.active { background: #FC8019; color: var(--text-main); }
.logout-btn { display: flex; align-items: center; gap: 14px; padding: 12px 16px; color: var(--color-red); cursor: pointer; font-size: 14px; font-weight: 500; border-radius: 10px; margin-top: auto; transition: background 0.2s; }
.logout-btn:hover { background: rgba(239, 68, 68, 0.1); }

/* ── MAIN CONTENT SYSTEM ── */
.main-content { margin-left: 260px; flex: 1; padding: 32px; max-width: calc(100vw - 260px); }
.header-panel { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
.welcome-msg h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
.welcome-msg p { color: var(--text-muted); font-size: 13px; }
.header-actions { display: flex; align-items: center; gap: 16px; }
.live-status { background: rgba(72, 196, 121, 0.1); color: var(--color-green); border: 1px solid rgba(72, 196, 121, 0.2); border-radius: 20px; padding: 6px 16px; font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
.live-pulse { width: 8px; height: 8px; background: var(--color-green); border-radius: 50%; box-shadow: 0 0 0 0 rgba(72, 196, 121, 0.7); animation: pulse-glow 1.5s infinite; }
@keyframes pulse-glow { 0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(72, 196, 121, 0.7); } 70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(72, 196, 121, 0); } 100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(72, 196, 121, 0); } }
.refresh-trigger { background: var(--bg-dark-surface); color: var(--text-main); border: 1px solid var(--border-line); border-radius: 10px; padding: 10px 20px; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.2s ease; }
.refresh-trigger:hover { background: var(--border-line); }

/* ── HIGH-LEVEL KPI METRIC CARDS ── */
.metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 32px; }
.kpi-card { background: var(--bg-dark-surface); border: 1px solid var(--border-line); border-radius: 16px; padding: 24px; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; }
.kpi-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; }
.kpi-card.sales::before { background: var(--color-green); }
.kpi-card.orders::before { background: var(--color-purple); }
.kpi-card.ticket::before { background: var(--color-blue); }
.kpi-card.tables::before { background: var(--color-orange); }
.kpi-info h3 { font-size: 13px; color: var(--text-muted); font-weight: 500; margin-bottom: 8px; }
.kpi-info h2 { font-size: 28px; font-weight: 700; }
.kpi-badge { align-self: flex-start; margin-top: 12px; font-size: 11px; font-weight: 600; padding: 4px 8px; border-radius: 6px; }
.sales .kpi-badge { background: rgba(72, 196, 121, 0.1); color: var(--color-green); }
.orders .kpi-badge { background: rgba(167, 139, 250, 0.1); color: var(--color-purple); }
.ticket .kpi-badge { background: rgba(96, 165, 250, 0.1); color: var(--color-blue); }
.tables .kpi-badge { background: rgba(245, 158, 11, 0.1); color: var(--color-orange); }

/* ── CHARTS INTERFACE SYSTEM ── */
.charts-grid { display: grid; grid-template-columns: 4fr 5fr; gap: 24px; margin-bottom: 32px; }
.chart-container { background: var(--bg-dark-surface); border: 1px solid var(--border-line); border-radius: 16px; padding: 24px; min-height: 340px; display: flex; flex-direction: column; }
.chart-title-wrapper { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.chart-title-wrapper h2 { font-size: 15px; font-weight: 600; }
.chart-title-wrapper select { background: var(--bg-dark-core); color: var(--text-main); border: 1px solid var(--border-line); padding: 4px 8px; border-radius: 6px; font-size: 12px; outline: none; }
.canvas-holder { flex: 1; position: relative; height: 100%; display: flex; align-items: center; justify-content: center; }

/* ── TRENDING MENU HORIZONTAL MARGIN GRID ── */
.trending-header { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
.trending-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 32px; }
.trend-card { background: var(--bg-dark-surface); border: 1px solid var(--border-line); border-radius: 16px; padding: 20px; display: flex; align-items: center; gap: 16px; transition: transform 0.2s ease; }
.trend-card:hover { transform: translateY(-2px); }
.trend-emoji { font-size: 36px; background: rgba(252, 128, 25, 0.1); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(252, 128, 25, 0.2); }
.trend-details { flex: 1; min-width: 0; }
.trend-name { font-size: 14px; font-weight: 600; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.trend-metric { font-size: 12px; color: var(--text-muted); }
.trend-rank { font-size: 13px; font-weight: 700; color: #FC8019; background: rgba(252, 128, 25, 0.1); padding: 4px 10px; border-radius: 20px; }

/* ── DATA REGION OVERLAYS ── */
.view-panel { display: none; }
.view-panel.active-panel { display: block; }
.table-card { background: var(--bg-dark-surface); border: 1px solid var(--border-line); border-radius: 16px; overflow: hidden; }
.grid-table { width: 100%; border-collapse: collapse; text-align: left; font-size: 13px; }
.grid-table th { background: #1C2331; color: var(--text-muted); font-weight: 500; padding: 16px 20px; font-size: 12px; border-bottom: 1px solid var(--border-line); }
.grid-table td { padding: 16px 20px; border-bottom: 1px solid var(--border-line); color: var(--text-main); }
.grid-table tr:hover td { background: rgba(255,255,255,0.02); }
.status-pill { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; display: inline-block; background: rgba(72, 196, 121, 0.1); color: var(--color-green); }

.loading-mask { text-align: center; padding: 60px; color: var(--text-muted); font-size: 14px; font-weight: 500; }
</style>
</head>
<body style="display: none;" id="authWrapper">

  <nav class="sidebar">
    <div class="brand-box">
      <span class="brand-logo">🧑‍🍳</span>
      <span class="brand-name">Chef Nishanth</span>
    </div>
    <ul class="nav-list">
      <li class="nav-item active" onclick="switchTab('dashboard', this)">🖥️ Dashboard</li>
      <li class="nav-item" onclick="switchTab('logs', this)">📋 Order Analytics Grid</li>
    </ul>
    <div class="logout-btn" onclick="location.reload()">🔒 System Lock</div>
  </nav>

  <main class="main-content">
    
    <header class="header-panel">
      <div class="welcome-msg">
        <h1 id="panelContextTitle">Welcome Back, Chef Nishanth 👋</h1>
        <p>Live Stream Pipeline Room · Church Street Operations</p>
      </div>
      <div class="header-actions">
        <div class="live-status"><div class="live-pulse"></div>Live Cloud Sync</div>
        <button class="refresh-trigger" onclick="pullEcosystemData()">Sync System Feed</button>
      </div>
    </header>

    <div id="dashboardView" class="view-panel active-panel">
      
      <section class="metrics-grid">
        <div class="kpi-card sales"><div class="kpi-info"><h3>Today's Gross Sales</h3><h2 id="kpiSales">₹0</h2></div><span class="kpi-badge">Live Value</span></div>
        <div class="kpi-card orders"><div class="kpi-info"><h3>Total Tickets Logs</h3><h2 id="kpiOrders">0</h2></div><span class="kpi-badge">Gross Count</span></div>
        <div class="kpi-card ticket"><div class="kpi-info"><h3>Average Ticket Size</h3><h2 id="kpiTicket">₹0</h2></div><span class="kpi-badge">AOV Metric</span></div>
        <div class="kpi-card tables"><div class="kpi-info"><h3>Active Dining Tables</h3><h2 id="kpiTables">0</h2></div><span class="kpi-badge">Active Grid</span></div>
      </section>

      <section class="charts-grid">
        <div class="chart-container">
          <div class="chart-title-wrapper"><h2>Sales Streams Mix</h2><select><option>Current Categories</option></select></div>
          <div class="canvas-holder"><canvas id="mixChartMesh"></canvas></div>
        </div>
        <div class="chart-container">
          <div class="chart-title-wrapper"><h2>Hourly Sales Velocity</h2><select><option>Real-Time Frequency</option></select></div>
          <div class="canvas-holder"><canvas id="velocityChartMesh"></canvas></div>
        </div>
      </section>

      <div class="trending-header">🔥 Top Trending Menu Dishes Right Now</div>
      <section class="trending-grid" id="trendingItemsMesh">
        <div style="grid-column: 1/-1; text-align: center; color: var(--text-muted); font-size: 13px;">Computing dish acceleration rates...</div>
      </section>
    </div>

    <div id="logsView" class="view-panel">
      <div class="table-card">
        <div class="table-header"><div class="table-header-title">Raw Database Row Audit Stream (Sheet1)</div></div>
        <div id="loadingElement" class="loading-mask">Mapping tracking grid cell arrays...</div>
        <table class="grid-table" id="ordersTable" style="display: none;">
          <thead>
            <tr>
              <th>Date</th>
              <th>Time</th>
              <th>Table Number</th>
              <th>Dish Item Details</th>
              <th>Quantity</th>
              <th>Unit Cost</th>
              <th>Row Subtotal</th>
              <th>Complete Bill</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>

  </main>

<script>
  const MANAGER_PIN = "7019";
  const SPREADSHEET_ID = '1sFdtQFP7BdQQJ_0_SGbsqGh5kHV_VwvdtG3261-3-vk';
  
  // Mapping reference index values for algorithmic asset categorization
  const MENU_MAP = {
    'Crispy Chicken Lollipop': { cat: 'Starters', emoji: '🍗' },
    'Paneer Tikka Royale': { cat: 'Starters', emoji: '🫑' },
    'Mutton Seekh Kebab': { cat: 'Starters', emoji: '🍢' },
    'Hara Bhara Kebab': { cat: 'Starters', emoji: '🥗' },
    'Butter Chicken Masala': { cat: 'Mains', emoji: '🍛' },
    'Lamb Rogan Josh': { cat: 'Mains', emoji: '5' },
    'Palak Paneer Nishanth Style': { cat: 'Mains', emoji: '🌿' },
    'Prawn Malvani Curry': { cat: 'Mains', emoji: '🦐' },
    'Hyderabadi Dum Gosht Biryani': { cat: 'Biryani', emoji: '🍚' },
    'Coastal Prawn Biryani': { cat: 'Biryani', emoji: '🍤' },
    'Nizami Vegetable Dum Biryani': { cat: 'Biryani', emoji: '🌾' },
    'Butter Naan': { cat: 'Breads', emoji: '🫓' },
    'Garlic Kulcha': { cat: 'Breads', emoji: '🧄' },
    'Lachha Paratha': { cat: 'Breads', emoji: '🥞' },
    'Gulab Jamun with Ice Cream': { cat: 'Desserts', emoji: '🍮' },
    'Mango Phirni': { cat: 'Desserts', emoji: '🥭' },
    'Chocolate Lava Rabdi': { cat: 'Desserts', emoji: '🍫' },
    'Masala Chai': { cat: 'Drinks', emoji: '☕' },
    'Rose Sharbat': { cat: 'Drinks', emoji: '🌹' },
    'Mango Lassi': { cat: 'Drinks', emoji: '🥤' }
  };

  let mixChartInstance = null;
  let velocityChartInstance = null;

  function runAuthenticationGateway() {
    const pin = prompt("🔑 Access Restricted. Enter Executive Manager Security PIN to initialize:");
    if (pin === MANAGER_PIN) {
      document.getElementById('authWrapper').style.display = 'flex';
      pullEcosystemData();
    } else {
      alert("❌ Authentication Failure. Access Denied.");
      location.reload();
    }
  }

  function switchTab(target, menuButton) {
    document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.view-panel').forEach(el => el.classList.remove('active-panel'));
    
    menuButton.classList.add('active');
    if (target === 'dashboard') {
      document.getElementById('dashboardView').classList.add('active-panel');
      document.getElementById('panelContextTitle').textContent = "Welcome Back, Chef Nishanth 👋";
    } else {
      document.getElementById('logsView').classList.add('active-panel');
      document.getElementById('panelContextTitle').textContent = "Database Audit Log System";
    }
  }

  async function pullEcosystemData() {
    const loadingMask = document.getElementById('loadingElement');
    const ordersTable = document.getElementById('ordersTable');
    const tableBody = document.getElementById('tableBody');
    
    try {
      loadingMask.style.display = 'block';
      loadingMask.textContent = 'Querying structural cloud endpoint records...';
      
      const csvQueryEndpoint = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:csv&sheet=Sheet1`;
      const response = await fetch(csvQueryEndpoint);
      if (!response.ok) throw new Error("Database transaction protocol rejected.");
      
      const dataString = await response.text();
      const stringRows = dataString.split(/\r?\n/);
      
      // Sanitizes rows cleanly across string components natively
      const structuralRows = stringRows.map(rowStr => {
        return rowStr.split(/,(?=(?:[^"]*"[^"]*")*[^"]*$)/).map(cell => cell.replace(/^"|"$/g, '').trim());
      });

      tableBody.innerHTML = '';
      let runningRevenueTotal = 0;
      let uniqueTableInstances = new Set();
      let quantifiedTicketCount = 0;

      let categoryDistributionMap = { 'Starters': 0, 'Mains': 0, 'Biryani': 0, 'Breads': 0, 'Desserts': 0, 'Drinks': 0 };
      let timeDistributionMatrix = {};
      let itemVolumeAggregation = {};

      for (let i = 1; i < structuralRows.length; i++) {
        const columns = structuralRows[i];
        if (!columns[0] || columns.length < 7) continue;

        quantifiedTicketCount++;
        const rowValueSubtotal = parseFloat(columns[6]) || 0;
        runningRevenueTotal += rowValueSubtotal;
        
        if (columns[2]) uniqueTableInstances.add(columns[2]);

        // Process Category Mix Data
        const itemIdentifier = columns[3];
        if (MENU_MAP[itemIdentifier]) {
          const categoryRef = MENU_MAP[itemIdentifier].cat;
          categoryDistributionMap[categoryRef] += rowValueSubtotal;
        }

        // Process Hourly Trend Data
        const timeMarker = columns[1];
        if (timeMarker) {
          const hourSection = timeMarker.split(':')[0] + ' ' + timeMarker.split(' ')[1];
          timeDistributionMatrix[hourSection] = (timeDistributionMatrix[hourSection] || 0) + rowValueSubtotal;
        }

        // Process Item Velocity Count
        if (itemIdentifier) {
          itemVolumeAggregation[itemIdentifier] = (itemVolumeAggregation[itemIdentifier] || 0) + (parseInt(columns[4]) || 1);
        }

        // Generate data grid row components
        const tableRowElement = document.createElement('tr');
        tableRowElement.innerHTML = `
          <td><b>${columns[0]}</b></td>
          <td>${columns[1] || ''}</td>
          <td><span style="color:#fc8019; font-weight:600;">Table ${columns[2] || ''}</span></td>
          <td>${itemIdentifier || ''}</td>
          <td>${columns[4] || '0'}</td>
          <td>₹${columns[5] || '0'}</td>
          <td>₹${rowValueSubtotal}</td>
          <td><b>₹${columns[7] || '0'}</b></td>
          <td><span class="status-pill">${columns[8] || 'New'}</span></td>
        `;
        tableBody.appendChild(tableRowElement);
      }

      if (quantifiedTicketCount === 0) {
        loadingMask.textContent = 'Database network live clear. No matching metrics recorded.';
        ordersTable.style.display = 'none';
        return;
      }

      // Render Consolidated KPIs
      document.getElementById('kpiSales').textContent = '₹' + runningRevenueTotal.toLocaleString('en-IN');
      document.getElementById('kpiOrders').textContent = quantifiedTicketCount;
      document.getElementById('kpiTicket').textContent = '₹' + (runningRevenueTotal / quantifiedTicketCount).toFixed(0);
      document.getElementById('kpiTables').textContent = uniqueTableInstances.size;

      // Compile Analytics Chart Projections
      renderMixMeshChart(categoryDistributionMap);
      renderVelocityMeshChart(timeDistributionMatrix);
      renderAcceleratedTrendingGrid(itemVolumeAggregation);

      loadingMask.style.display = 'none';
      ordersTable.style.display = 'table';
      
    } catch (error) {
      console.error(error);
      loadingMask.textContent = 'Database sync failure. Verify system macro execution context settings parameters. ❌';
    }
  }

  function renderMixMeshChart(mixData) {
    const element = document.getElementById('mixChartMesh').getContext('2d');
    if (mixChartInstance) mixChartInstance.destroy();
    
    mixChartInstance = new Chart(element, {
      type: 'doughnut',
      data: {
        labels: Object.keys(mixData),
        datasets: [{
          data: Object.values(mixData),
          backgroundColor: ['#48C479', '#A78BFA', '#60A5FA', '#F59E0B', '#EF4444', '#EC4899'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'right', labels: { color: '#8A94A6', font: { family: 'Poppins', size: 11 } } }
        }
      }
    });
  }

  function renderVelocityMeshChart(timeData) {
    const element = document.getElementById('velocityChartMesh').getContext('2d');
    if (velocityChartInstance) velocityChartInstance.destroy();
    
    // Sort array timeline hours accurately
    const sortedHours = Object.keys(timeData);
    const metricsValue = sortedHours.map(h => timeData[h]);

    velocityChartInstance = new Chart(element, {
      type: 'bar',
      data: {
        labels: sortedHours,
        datasets: [{
          label: 'Hourly Gross Volume',
          data: metricsValue,
          backgroundColor: '#FC8019',
          borderRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#8A94A6', font: { family: 'Poppins', size: 10 } } },
          y: { grid: { color: '#2D3748' }, ticks: { color: '#8A94A6', font: { family: 'Poppins', size: 10 } } }
        }
      }
    });
  }

  function renderAcceleratedTrendingGrid(volumeData) {
    const gridMesh = document.getElementById('trendingItemsMesh');
    
    const elementsSorted = Object.keys(volumeData).sort((x, y) => volumeData[y] - volumeData[x]).slice(0, 3);
    
    let htmlGridStructure = '';
    elementsSorted.forEach((itemName, index) => {
      const configRef = MENU_MAP[itemName] || { emoji: '🍛', cat: 'Mains' };
      htmlGridStructure += `
        <div class="trend-card">
          <div class="trend-emoji">${configRef.emoji}</div>
          <div class="trend-details">
            <div class="trend-name">${itemName}</div>
            <div class="trend-metric">${volumeData[itemName]} Units Ordered Today</div>
          </div>
          <div class="trend-rank">#${index + 1}</div>
        </div>
      `;
    });
    
    gridMesh.innerHTML = htmlGridStructure || '<div style="grid-column: 1/-1; text-align: center; color: var(--text-muted);">No sales tracking registered yet.</div>';
  }

  // Automatic refresh polling interval sequence every 15 seconds
  setInterval(() => {
    if (document.getElementById('dashboardView').classList.contains('active-panel')) {
      pullEcosystemData();
    }
  }, 15000);

  window.onload = runAuthenticationGateway;
</script>
</body>
</html>
